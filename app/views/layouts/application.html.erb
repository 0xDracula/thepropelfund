<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="TheHackGrant. A grant for teens to build cool shit.">
    <meta property="og:title" content="TheHackGrant">
    <meta property="og:description" content="TheHackGrant. A grant for teens to build cool shit.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://thehackgrant.com">
    <meta property="og:image" content="https://thehackgrant.hackclub.dev/og.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="628">
    <meta property="og:site_name" content="TheHackGrant">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="TheHackGrant">
    <meta name="twitter:description" content="TheHackGrant. A grant for teens to build cool shit.">
    <meta name="twitter:image" content="https://thehackgrant.hackclub.dev/og.jpg">
    <title><%= content_for(:title) || "TheHackGrant" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/favicon.svg">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script async src="https://plausible.io/js/pa-20ZMRx3sykInmK4DPWw2k.js"></script>
    <script>
      ((window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        }),
        (plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          }));
      plausible.init();
    </script>
  </head>

  <body>
    <% flash.each do |type, message| %>
      <p class="flash flash-<%= type %>"><%= message %></p>
    <% end %>
    <%= yield %>
  </body>
</html>
